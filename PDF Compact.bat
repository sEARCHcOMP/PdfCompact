@echo off
REM ===================================================================
REM PDF Compact launcher
REM   - Double-click to launch
REM   - Silently checks GitHub for new version and overwrites local copy
REM   - Then opens pdf_compact_bundle.html in default browser
REM   - Keep this .bat and pdf_compact_bundle.html in the same folder
REM ===================================================================
chcp 65001 >nul 2>&1
cd /d "%~dp0"

REM Update check + overwrite (PowerShell, UTF-16LE base64 encoded)
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand 

REM Open the (now updated) bundle in default browser
start "" "pdf_compact_bundle.html"
exit
