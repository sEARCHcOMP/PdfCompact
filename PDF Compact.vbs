' ===================================================================
' PDF Compact launcher (silent / hidden window)
'   - Double-click to launch
'   - Silently checks GitHub for latest version, downloads if newer
'   - Opens pdf_compact_bundle.html in default browser
'   - No black command window, runs completely in background
' ===================================================================
Option Explicit

Dim sh, fso, currentDir, bundlePath, psCmd
Set sh  = CreateObject("WScript.Shell")
Set fso = CreateObject("Scripting.FileSystemObject")

' Resolve folder of this .vbs file
currentDir = fso.GetParentFolderName(WScript.ScriptFullName)
bundlePath = currentDir & "\pdf_compact_bundle.html"
sh.CurrentDirectory = currentDir

' PowerShell update-check + download (base64 encoded, hidden window)
psCmd = "powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -EncodedCommand " & _
  ""

' Run PowerShell hidden, wait until update finishes (0 = SW_HIDE, True = wait)
sh.Run psCmd, 0, True

' Open the (now updated) bundle in default browser
If fso.FileExists(bundlePath) Then
  sh.Run """" & bundlePath & """", 1, False
Else
  ' First-run failure: bundle didn't download (offline?)
  MsgBox "Download failed. Please check internet connection and try again.", _
         vbExclamation, "PDF Compact"
End If
